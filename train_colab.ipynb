   "source": [
    "# Cell 4: Download corpus books from Project Gutenberg (if missing)\n",
    "import requests, os\n",
    "\n",
    "os.makedirs('corpus', exist_ok=True)\n",
    "\n",
    "BOOKS = {\n",
    "    '11.txt':   'https://www.gutenberg.org/files/11/11-0.txt',    # Alice in Wonderland\n",
    "    '1661.txt': 'https://www.gutenberg.org/files/1661/1661-0.txt', # Sherlock Holmes\n",
    "    '84.txt':   'https://www.gutenberg.org/files/84/84-0.txt',    # Frankenstein\n",
    "    '1342.txt': 'https://www.gutenberg.org/files/1342/1342-0.txt', # Pride & Prejudice\n",
    "    '345.txt':  'https://www.gutenberg.org/files/345/345-0.txt',  # Dracula\n",
    "    '35.txt':   'https://www.gutenberg.org/files/35/35-0.txt',    # Time Machine\n",
    "    '2701.txt': 'https://www.gutenberg.org/files/2701/2701-0.txt', # Moby Dick\n",
    "    '76.txt':   'https://www.gutenberg.org/files/76/76-0.txt',    # Huck Finn\n",
    "    '98.txt':   'https://www.gutenberg.org/files/98/98-0.txt',    # Tale of Two Cities\n",
    "    '844.txt':  'https://www.gutenberg.org/files/844/844-0.txt',  # Being Earnest\n",
    "}\n",
    "\n",
    "for fname, url in BOOKS.items():\n",
    "    path = f'corpus/{fname}'\n",
    "    if os.path.exists(path):\n",
    "        size = os.path.getsize(path)\n",
    "        print(f'  Already have {fname} ({size/1024:.0f} KB)')\n",
    "        continue\n",
    "    try:\n",
    "        r = requests.get(url, timeout=30)\n",
    "        r.raise_for_status()\n",
    "        with open(path, 'wb') as f:\n",
    "            f.write(r.content)\n",
    "        print(f'  Downloaded {fname} ({len(r.content)/1024:.0f} KB)')\n",
    "    except Exception as e:\n",
    "        print(f'  FAILED {fname}: {e}')\n",
    "\n",
    "books = [f for f in os.listdir('corpus') if f.endswith('.txt')]\n",
    "print(f'\\nCorpus: {len(books)} books ready')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 5: Patch ingest.py to use GPU if available\n",
    "# This monkey-patches the device selection so training uses the T4 automatically\n",
    "import torch\n",
    "\n",
    "DEVICE = 'cuda' if torch.cuda.is_available() else 'cpu'\n",
    "print(f'Training device: {DEVICE}')\n",
    "\n",
    "# Read ingest.py and patch device\n",
    "with open('ingest.py', 'r', encoding='utf-8') as f:\n",
    "    content = f.read()\n",
    "\n",
    "# Inject device selection after imports if not already present\n",
    "if 'DEVICE = ' not in content:\n",
    "    content = content.replace(\n",
    "        'import torch',\n",
    "        'import torch\\nDEVICE = \"cuda\" if torch.cuda.is_available() else \"cpu\"\\nprint(f\"Using device: {DEVICE}\")'\n",
    "    )\n",
    "    # Replace .cpu() and manual device assignments\n",
    "    content = content.replace(\n",
    "        \"device = 'cpu'\",\n",
    "        \"device = DEVICE\"\n",
    "    ).replace(\n",
    "        'device = torch.device(\"cpu\")',\n",
    "        'device = torch.device(DEVICE)'\n",
    "    )\n",
    "    with open('ingest.py', 'w', encoding='utf-8') as f:\n",
    "        f.write(content)\n",
    "    print('Patched ingest.py for GPU')\n",
    "else:\n",
    "    print('ingest.py already has device selection')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 6: Run training — 15 iterations\n",
    "import subprocess, sys, os, time\n",
    "\n",
    "os.environ['PYTHONIOENCODING'] = 'utf-8'\n",
    "\n",
    "print('Starting Engram training — 15 iterations on', 'GPU' if torch.cuda.is_available() else 'CPU')\n",
    "print('This will take ~15-30 minutes on T4 GPU vs 10+ hours on CPU')\n",
    "print('=' * 60)\n",
    "\n",
    "start = time.time()\n",
    "proc = subprocess.Popen(\n",
    "    [sys.executable, '-u', 'train_runner.py', '1', '15'],\n",
    "    stdout=subprocess.PIPE,\n",
    "    stderr=subprocess.STDOUT,\n",
    "    text=True,\n",
    "    bufsize=1,\n",
    "    env={**os.environ, 'PYTHONIOENCODING': 'utf-8'}\n",
    ")\n",
    "\n",
    "for line in proc.stdout:\n",
    "    print(line, end='', flush=True)\n",
    "\n",
    "proc.wait()\n",
    "elapsed = time.time() - start\n",
    "print(f'\\nTraining finished in {elapsed/60:.1f} minutes (exit code {proc.returncode})')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 7: Check results\n",
    "import os, json\n",
    "\n",
    "# Weights\n",
    "weights = 'engram_weights.pth'\n",
    "if os.path.exists(weights):\n",
    "    size_mb = os.path.getsize(weights) / 1024 / 1024\n",
    "    print(f'Weights: {size_mb:.1f} MB')\n",
    "else:\n",
    "    print('WARNING: No weights file found!')\n",
    "\n",
    "# Training log\n",
    "log = 'training_log.jsonl'\n",
    "if os.path.exists(log):\n",
    "    lines = open(log).readlines()\n",
    "    print(f'Training log: {len(lines)} iterations')\n",
    "    for line in lines[-3:]:\n",
    "        try:\n",
    "            entry = json.loads(line)\n",
    "            print(f'  Iter {entry.get(\"iteration\")}: loss={entry.get(\"loss\", \"?\")}')\n",
    "        except:\n",
    "            print(' ', line.strip())\n",
    "\n",
    "# Eval results\n",
    "import glob\n",
    "evals = sorted(glob.glob('eval_runs/eval_results_*.json'))\n",
    "if evals:\n",
    "    print(f'Eval files: {len(evals)}')\n",
    "    latest = json.load(open(evals[-1]))\n",
    "    print(f'Latest eval: {evals[-1]}')\n",
    "    for k, v in list(latest.items())[:5]:\n",
    "        print(f'  {k}: {v}')"
   ]
